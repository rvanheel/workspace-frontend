{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Node: Launch index.js",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/index.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Node: Attach (9229)",
      "type": "node",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Run and Attach Debug",
      "configurations": ["Node: Attach (9229)"],
      "preLaunchTask": "npm: debug"
    }
  ]
}
